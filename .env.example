# Updated .env.example with new SaaS configuration

# AI API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here # Fallback if Gemini fails

# Twitter API (Optional - for trend detection)
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret

# Google Sheets (Legacy - will be replaced by PostgreSQL)
GOOGLE_SHEETS_CREDENTIALS_FILE=service_account.json
GOOGLE_SHEETS_NAME=Agency Content Calendar

# Admin Credentials (Legacy - for old dashboard)
ADMIN_USER=admin
ADMIN_PASS=changeme

# Database Configuration
# 'postgres' is the service name from docker-compose.yml
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/dexter

# JWT Authentication
# Generate a secure key with: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-use-openssl-rand-hex-32

# Stripe Payment Processing
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email Service (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=noreply@dexter.app

# AWS S3 (for file storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=dexter-uploads
AWS_REGION=us-east-1

# Redis (for Celery task queue)
REDIS_URL=redis://localhost:6379/0

# Application Settings
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
